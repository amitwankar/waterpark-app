# =========================
# App
# =========================
NODE_ENV=production # production|development|test
NEXT_PUBLIC_APP_URL=https://shivthirth.growbean.in # public app URL
PORT=3000 # internal app port in container
DOMAIN_NAME=https://shivthirth.growbean.in # primary do    main for nginx + cert paths

# =========================
# Database (PostgreSQL)
# =========================
POSTGRES_DB=aquaworld # create database name
POSTGRES_USER=aquaworld # create database user
POSTGRES_PASSWORD=postgres # use a long random password
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/waterpark_app?schema=public # runtime DB URL
DIRECT_URL=postgresql://aquaworld:postgres@db:5432/aquaworld?schema=public # prisma direct URL

# =========================
# Redis
# =========================
REDIS_PASSWORD=postgres # use a long random password
REDIS_URL=redis://localhost:6379 # app redis URL
REDIS_BULL_URL=redis://:postgres@redis:6379 # bullmq redis URL

# =========================
# Better Auth
# =========================
BETTER_AUTH_URL=https://shivthirth.growbean.in # same as app URL
BETTER_AUTH_SECRET=rVm4KmNBQRO58klvmy4cwmgazPtZGluN4z6xyvJdIBQ= # openssl rand -base64 48
BETTER_AUTH_TRUSTED_ORIGINS=https://shivthirth.growbean.in # comma-separated list

# =========================
# Encryption
# =========================
ENCRYPTION_KEY=12345678901234567890123456789012 # exactly 32 chars, openssl rand -hex 16

# =========================
# Razorpay
# =========================
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx # production key id
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx # production key secret
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxx # webhook signing secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx # same as key id for frontend

# =========================
# UPI
# =========================
PARK_UPI_ID=aquaworld@ybl # park collection UPI ID

# =========================
# MSG91
# =========================
MSG91_AUTH_KEY=xxxxxxxxxxxxxxxxxxxx # MSG91 auth key
MSG91_SENDER_ID=AQUAWD # approved sender ID
MSG91_WHATSAPP_NUMBER=919999999999 # approved integrated whatsapp number

# =========================
# SMTP
# =========================
SMTP_HOST=smtp.example.com # SMTP hostname
SMTP_PORT=587 # SMTP port (587 TLS / 465 SSL)
SMTP_USER=no-reply@example.com # SMTP username
SMTP_PASS=xxxxxxxxxxxxxxxxxxxx # SMTP password/app-password
SMTP_FROM_EMAIL=no-reply@example.com # outgoing from email
SMTP_FROM_NAME=AquaWorld Park # outgoing from display name

# =========================
# Uploads
# =========================
UPLOADS_DIR=/opt/aquaworld/uploads # host path mounted to app/nginx
