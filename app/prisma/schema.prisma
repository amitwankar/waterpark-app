// =============================================================================
// Waterpark & Amusement Park Management — Prisma Schema
// ORM      : Prisma 7.3.0
// Database : PostgreSQL 17.4
// Auth     : Better Auth (user / session / account / verification tables)
// Timezone : All timestamps stored in UTC; displayed as IST (UTC+5:30) in app
// IDs      : cuid() — URL-safe, collision-resistant, lexicographically sortable
// Money    : Decimal(12,2) — supports values up to ₹9,999,999,999.99
// Rates    : Decimal(5,2)  — supports up to 999.99%
// Delete   : Soft (isDeleted + deletedAt) for audit-critical data
//            Hard delete only for transient/session data (per-model notes)
// Naming   : Prisma models → PascalCase  |  DB tables  → snake_case via @@map
//            Prisma fields → camelCase   |  DB columns → snake_case via @map
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  ADMIN
  EMPLOYEE
  USER
}

enum EmployeeSubRole {
  TICKET_COUNTER
  FB_STAFF
  RIDE_OPERATOR
  MAINTENANCE_TECH
  LOCKER_ATTENDANT
  COSTUME_ATTENDANT
  SALES_EXECUTIVE
  SECURITY_STAFF
  EVENT_COORDINATOR
}

enum BookingStatus {
  PENDING // created, awaiting payment confirmation
  CONFIRMED // payment received and verified
  CHECKED_IN // guest scanned at entry gate
  COMPLETED // visit ended
  CANCELLED // cancelled before visit (transaction may be REFUNDED)
}

// No REFUNDED on BookingStatus intentionally.
// Refunds live on Transaction.status = REFUNDED.
// A CANCELLED booking can have a Transaction with status = REFUNDED.

enum TransactionMethod {
  GATEWAY // Razorpay online payment
  MANUAL_UPI // guest uploads UPI screenshot; admin verifies
  CASH // collected at POS by TICKET_COUNTER staff
  CARD // debit/credit card swipe at POS
  WRISTBAND // RFID wristband charge (Phase 2)
  COMPLIMENTARY // complimentary / zero-cost ticket
}

enum PosSessionStatus {
  OPEN
  CLOSED
}

enum TransactionStatus {
  PENDING // awaiting confirmation
  PAID // confirmed payment
  FAILED // gateway or OTP failure
  REFUNDED // amount returned to guest
  REJECTED // manual UPI screenshot rejected by admin
}

enum RideStatus {
  ACTIVE
  MAINTENANCE
  CLOSED
  SEASONAL
}

enum LeadSource {
  WEBSITE
  WHATSAPP
  PHONE
  WALKIN
  SOCIAL
  REFERRAL
  EVENT
}

enum LeadStage {
  NEW
  CONTACTED
  INTERESTED
  PROPOSAL_SENT
  BOOKED
  LOST
}

enum GuestTier {
  BRONZE //     0 – 499 pts
  SILVER //   500 – 1,999 pts
  GOLD // 2,000 – 4,999 pts
  PLATINUM // 5,000+ pts
}

enum LoyaltyType {
  EARN // points credited on booking / visit
  REDEEM // points debited against booking discount
  EXPIRE // periodic expiry run
  ADJUST // manual admin correction
}

enum WorkOrderPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum WorkOrderStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum CouponDiscountType {
  PERCENTAGE
  FLAT
  PERCENTAGE_DISCOUNT
  FLAT_DISCOUNT
  FREE_TICKET
  BUY_X_GET_Y
  FLAT_PER_TICKET
  FOOD_DISCOUNT
  LOCKER_FREE
}

enum CouponTarget {
  ALL
  MEMBER_ONLY
  TIER_SPECIFIC
  FIRST_VISIT
  CORPORATE
  BIRTHDAY_MONTH
  NEW_USER
}

enum CouponAppliesTo {
  ALL_TICKETS
  SPECIFIC_TICKETS
  ADULTS_ONLY
  CHILDREN_ONLY
}

enum WeekDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum IdProofType {
  AADHAAR
  DRIVING_LICENSE
  PAN
  PASSPORT
  VOTER_ID
  OTHER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum ShiftType {
  MORNING // 06:00–14:00
  AFTERNOON // 14:00–22:00
  EVENING // 14:00–22:00 (configurable alias)
  NIGHT // 22:00–06:00
}

enum CommunicationChannel {
  SMS
  WHATSAPP
  EMAIL
  PUSH
}

enum MessageStatus {
  QUEUED
  SENT
  FAILED
}

// ─── Food & Beverage ──────────────────────────────────────────────────────────

enum FoodOrderStatus {
  PENDING // created, not yet started
  PREPARING // kitchen is making it
  READY // ready for collection, token called
  DELIVERED // handed to guest
  CANCELLED
}

enum FnbPaymentMethod {
  CASH
  UPI
  WRISTBAND // Phase 2 RFID charge
}

// ─── Lockers ──────────────────────────────────────────────────────────────────

enum LockerSize {
  SMALL
  MEDIUM
  LARGE
}

enum LockerStatus {
  AVAILABLE
  ASSIGNED
  RETURNED // transitional: returned, pending cleaning before AVAILABLE
  MAINTENANCE
}

enum LockerDurationType {
  HOURLY
  FULL_DAY
}

// =============================================================================
// COSTUME RENTAL
// =============================================================================

enum CostumeStatus {
  AVAILABLE
  RENTED
  RETURNED // transitional — pending inspection/laundry before AVAILABLE
  MAINTENANCE // damaged / being repaired
}

enum CostumeSize {
  XS
  S
  M
  L
  XL
  XXL
  KIDS_S // Kids Small  (3-5 yrs)
  KIDS_M // Kids Medium (6-9 yrs)
  KIDS_L // Kids Large  (10-12 yrs)
}

enum PackageItemType {
  TICKET
  RIDE
  LOCKER
  COSTUME
  FOOD
}

// =============================================================================
// BETTER AUTH — CORE TABLES
// These four models match Better Auth's required schema exactly.
// Fields named and typed per Better Auth Prisma adapter conventions.
// Custom park fields added to User only.
// =============================================================================

/// Primary identity record for all users (ADMIN, EMPLOYEE, USER/guest).
/// Better Auth writes: id, name, email, emailVerified, image, createdAt, updatedAt.
/// Park additions: mobile, mobileVerified, passwordHash, role, subRole, isActive.
/// Soft delete: yes — staff/admin accounts must be preserved for audit trail.
model User {
  id             String           @id @default(cuid())
  name           String
  email          String?          @unique
  emailVerified  Boolean          @default(false) @map("email_verified")
  image          String?
  mobile         String           @unique
  mobileVerified Boolean          @default(false) @map("mobile_verified")
  passwordHash   String?          @map("password_hash") // managed via Account.password by Better Auth; mirrored here for direct lookup
  role           UserRole         @default(USER)
  subRole        EmployeeSubRole? @map("sub_role")
  isActive       Boolean          @default(true) @map("is_active")
  isDeleted      Boolean          @default(false) @map("is_deleted")
  deletedAt      DateTime?        @map("deleted_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  // Better Auth relations
  sessions Session[]
  accounts Account[]

  // Domain relations
  bookings             Booking[]
  couponRedemptions    CouponRedemption[]
  staffProfile         StaffProfile?
  assignedLeads        Lead[]             @relation("LeadAssignee")
  leadActivitiesBy     LeadActivity[]
  verifiedTransactions Transaction[]      @relation("TransactionVerifier")
  workOrdersAssigned   WorkOrder[]        @relation("WorkOrderAssignee")
  workOrdersCreated    WorkOrder[]        @relation("WorkOrderCreator")
  operatedRides        Ride[]             @relation("RideOperator")
  foodOrdersAsStaff    FoodOrder[]        @relation("FoodOrderStaff")
  lockerAssignmentsBy  LockerAssignment[] @relation("LockerAssignedBy")
  lockerReturnsBy      LockerAssignment[] @relation("LockerReturnedBy")
  posSessions          PosSession[]       @relation("PosSessionStaff")
  costumeRentalsBy     CostumeRental[]    @relation("CostumeRentedBy")
  costumeReturnsBy     CostumeRental[]    @relation("CostumeReturnedBy")

  @@index([mobile])
  @@index([email])
  @@index([role])
  @@index([subRole])
  @@index([isActive, isDeleted])
  @@map("user")
}

/// Device session. One row per active login.
/// Hard delete: Better Auth auto-purges expired sessions.
model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime @map("expires_at")
  token     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("session")
}

/// Auth provider account (credential / OAuth).
/// password field holds bcrypt hash when using email+password provider.
/// Hard delete: cascades on User deactivation (handled in application layer).
model Account {
  id                    String    @id @default(cuid())
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token") @db.Text
  refreshToken          String?   @map("refresh_token") @db.Text
  idToken               String?   @map("id_token") @db.Text
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([providerId, accountId])
  @@map("account")
}

/// Short-lived verification tokens for OTP and email links.
/// identifier = mobile number (guest OTP) or email address (staff email verify).
/// Hard delete: Better Auth purges after use or expiry.
model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String   @db.Text // hashed OTP value or signed token
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([identifier])
  @@index([expiresAt])
  @@map("verification")
}

// =============================================================================
// PARK CONFIGURATION
// =============================================================================

/// Global park settings. SINGLETON — exactly one row, update in place only.
/// No soft delete. Single-row enforcement: application prevents creating a second row.
/// loyaltyPointsPerRupee: how many points are credited per ₹1 spent.
/// SINGLETON — always upsert with id = "singleton". Never create a second row.
model ParkConfig {
  id String @id @default(cuid())

  // ── General ──────────────────────────────────────────────────────────────
  parkName   String  @map("park_name")
  address    String? @db.Text
  city       String?
  state      String?
  pincode    String?
  phone      String?
  email      String?
  logoUrl    String? @map("logo_url")
  websiteUrl String? @map("website_url")
  timezone   String  @default("Asia/Kolkata") @map("timezone")

  // ── Pricing & Tax ────────────────────────────────────────────────────────
  defaultGstRate     Decimal @default(18) @map("default_gst_rate") @db.Decimal(5, 2)
  foodGstRate        Decimal @default(5) @map("food_gst_rate") @db.Decimal(5, 2)
  lockerGstRate      Decimal @default(18) @map("locker_gst_rate") @db.Decimal(5, 2)
  gstNumber          String? @map("gst_number") // GSTIN 15-char
  invoicePrefix      String  @default("INV") @map("invoice_prefix")
  invoiceStartNumber Int     @default(1000) @map("invoice_start_number")

  // ── Loyalty ──────────────────────────────────────────────────────────────
  loyaltyEnabled        Boolean @default(true) @map("loyalty_enabled")
  loyaltyPointsPerRupee Decimal @default(1) @map("loyalty_points_per_rupee") @db.Decimal(5, 2)
  pointRedeemValue      Decimal @default(0.50) @map("point_redeem_value") @db.Decimal(5, 2) // ₹ per point
  maxRedeemPercent      Decimal @default(20) @map("max_redeem_percent") @db.Decimal(5, 2) // % of order
  pointsExpiryDays      Int     @default(365) @map("points_expiry_days")

  // ── Payment ──────────────────────────────────────────────────────────────
  razorpayEnabled        Boolean @default(false) @map("razorpay_enabled")
  razorpayKeyId          String? @map("razorpay_key_id") // stored encrypted / masked in API
  razorpayKeySecret      String? @map("razorpay_key_secret") // stored encrypted / masked in API
  manualUpiEnabled       Boolean @default(true) @map("manual_upi_enabled")
  upiId                  String? @map("upi_id")
  upiName                String? @map("upi_name")
  upiQrImageUrl          String? @map("upi_qr_image_url")
  depositEnabled         Boolean @default(false) @map("deposit_enabled")
  depositPercent         Decimal @default(30) @map("deposit_percent") @db.Decimal(5, 2)
  depositLabel           String  @default("Advance") @map("deposit_label")
  splitEnabled           Boolean @default(false) @map("split_enabled")
  maxSplitMethods        Int     @default(4) @map("max_split_methods")
  minSplitAmount         Decimal @default(50) @map("min_split_amount") @db.Decimal(12, 2)
  refundDeductionPercent Decimal @default(0) @map("refund_deduction_percent") @db.Decimal(5, 2)

  // ── Capacity & Booking Rules ──────────────────────────────────────────────
  maxCapacityPerDay    Int     @default(2000) @map("max_capacity_per_day")
  idProofEnabled       Boolean @default(true) @map("id_proof_enabled")
  idProofRequiredAbove Int     @default(10) @map("id_proof_required_above")
  minDaysAhead         Int     @default(0) @map("min_days_ahead") // 0 = same-day allowed
  maxDaysAhead         Int     @default(90) @map("max_days_ahead")
  bookingCutoffHour    Int     @default(23) @map("booking_cutoff_hour") // hour (0–23) after which same-day blocked
  maxTicketsPerBooking Int     @default(20) @map("max_tickets_per_booking")

  // ── Operating Hours (JSON array of 7 day objects) ────────────────────────
  // Format: [{ day: 0, isOpen: true, openTime: "09:00", closeTime: "20:00" }]
  // day: 0=Mon … 6=Sun
  operatingHours Json? @map("operating_hours")

  // ── Notifications ─────────────────────────────────────────────────────────
  notifyBookingConfirm  Boolean @default(true) @map("notify_booking_confirm")
  notifyCheckin         Boolean @default(true) @map("notify_checkin")
  notifyPaymentReceived Boolean @default(true) @map("notify_payment_received")
  notifyRefund          Boolean @default(true) @map("notify_refund")
  notifyLoyaltyPoints   Boolean @default(true) @map("notify_loyalty_points")
  whatsappEnabled       Boolean @default(false) @map("whatsapp_enabled")
  whatsappApiKey        String? @map("whatsapp_api_key") // masked in API
  smsEnabled            Boolean @default(false) @map("sms_enabled")
  smsApiKey             String? @map("sms_api_key") // masked in API

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("park_config")
}

enum HolidayType {
  CLOSED
  SPECIAL_HOURS
  SPECIAL_EVENT
}

/// Park holiday / special day override.
/// CLOSED dates auto-block the booking date picker.
model ParkHoliday {
  id               String      @id @default(cuid())
  date             DateTime    @db.Date
  name             String
  type             HolidayType @default(CLOSED)
  specialOpenTime  String?     @map("special_open_time") // "HH:MM" — only for SPECIAL_HOURS
  specialCloseTime String?     @map("special_close_time")
  message          String?     @db.Text
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  @@unique([date])
  @@index([date])
  @@map("park_holiday")
}

/// Immutable audit trail for significant actions.
/// Hard delete: never — compliance requirement.
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id") // null for system actions
  userRole  String?  @map("user_role")
  action    String // e.g. "settings.update", "booking.cancel"
  entity    String // e.g. "ParkConfig", "Booking"
  entityId  String?  @map("entity_id")
  oldValue  Json?    @map("old_value")
  newValue  Json?    @map("new_value")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent") @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_log")
}

/// Physical zone within the park (Wave Pool Zone, Adventure Zone, etc.).
/// Soft delete: isActive flag. Hard delete avoided — rides reference zones.
model Zone {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  rides Ride[]

  @@index([isActive])
  @@map("zone")
}

// =============================================================================
// TICKETS
// =============================================================================

/// Ticket product catalog (Adult Day Pass, Child Pass, Couple Pass, etc.).
/// Prices are SNAPSHOTTED onto BookingTicket at purchase time.
/// Changing price / gstRate here does NOT retroactively affect existing bookings.
/// Soft delete: isDeleted — BookingTicket references must remain resolvable.
model TicketType {
  id            String    @id @default(cuid())
  name          String
  description   String?   @db.Text
  price         Decimal   @db.Decimal(12, 2)
  gstRate       Decimal   @default(18) @map("gst_rate") @db.Decimal(5, 2)
  validDays     Int       @default(1) @map("valid_days") // 1 = single-day, 2+ = multi-day pass
  minAge        Int?      @map("min_age") // null = no age restriction
  maxAge        Int?      @map("max_age")
  rideId        String?   @map("ride_id") // optional: ride-specific entitlement ticket
  maxPerBooking Int?      @map("max_per_booking") // null = unlimited per booking
  sortOrder     Int       @default(0) @map("sort_order")
  isActive      Boolean   @default(true) @map("is_active")
  isDeleted     Boolean   @default(false) @map("is_deleted")
  deletedAt     DateTime? @map("deleted_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  bookingTickets      BookingTicket[]
  bookingParticipants BookingParticipant[]
  couponTicketTypes   CouponTicketType[]
  freeTicketCoupons   Coupon[]             @relation("CouponFreeTicketType")
  ride                Ride?                @relation(fields: [rideId], references: [id])
  packageItems        SalesPackageItem[]   @relation("PackageTicketType")

  @@index([isActive, isDeleted])
  @@index([sortOrder])
  @@index([rideId])
  @@map("ticket_type")
}

model SalesPackage {
  id          String    @id @default(cuid())
  name        String
  description String?   @db.Text
  listedPrice Decimal   @map("listed_price") @db.Decimal(12, 2)
  salePrice   Decimal   @map("sale_price") @db.Decimal(12, 2)
  gstRate     Decimal   @default(18) @map("gst_rate") @db.Decimal(5, 2)
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  isDeleted   Boolean   @default(false) @map("is_deleted")
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  items SalesPackageItem[]

  @@index([isActive, isDeleted])
  @@index([sortOrder])
  @@map("sales_package")
}

model SalesPackageItem {
  id             String          @id @default(cuid())
  packageId      String          @map("package_id")
  itemType       PackageItemType @map("item_type")
  ticketTypeId   String?         @map("ticket_type_id")
  rideId         String?         @map("ride_id")
  lockerId       String?         @map("locker_id")
  costumeItemId  String?         @map("costume_item_id")
  foodItemId     String?         @map("food_item_id")
  foodVariantId  String?         @map("food_variant_id")
  quantity       Int             @default(1)
  sortOrder      Int             @default(0) @map("sort_order")
  createdAt      DateTime        @default(now()) @map("created_at")

  package     SalesPackage     @relation(fields: [packageId], references: [id], onDelete: Cascade)
  ticketType  TicketType?      @relation("PackageTicketType", fields: [ticketTypeId], references: [id])
  ride        Ride?            @relation("PackageRide", fields: [rideId], references: [id])
  locker      Locker?          @relation("PackageLocker", fields: [lockerId], references: [id])
  costumeItem CostumeItem?     @relation("PackageCostumeItem", fields: [costumeItemId], references: [id])
  foodItem    FoodItem?        @relation("PackageFoodItem", fields: [foodItemId], references: [id])
  foodVariant FoodItemVariant? @relation("PackageFoodVariant", fields: [foodVariantId], references: [id])

  @@index([packageId])
  @@index([itemType])
  @@index([ticketTypeId])
  @@index([rideId])
  @@index([lockerId])
  @@index([costumeItemId])
  @@index([foodItemId])
  @@index([foodVariantId])
  @@map("sales_package_item")
}

// =============================================================================
// BOOKINGS
// =============================================================================

/// One booking = one visit by a guest, may span multiple ticket types.
/// Status machine: PENDING → CONFIRMED → CHECKED_IN → COMPLETED
///                 PENDING | CONFIRMED → CANCELLED
/// No soft delete — status transitions ARE the audit trail.
/// qrCode is the unique token embedded in the guest's QR code at entry.
/// bookingNumber is the human-readable reference shown to the guest.
model Booking {
  id             String        @id @default(cuid())
  bookingNumber  String        @unique @default(cuid()) @map("booking_number") // shown to guest e.g. "clxxxxxxxx"
  userId         String?       @map("user_id") // null for unregistered guest bookings
  guestName      String        @map("guest_name")
  guestMobile    String        @map("guest_mobile")
  guestEmail     String?       @map("guest_email")
  visitDate      DateTime      @map("visit_date") @db.Date // DATE only, no time component; stored UTC midnight
  adults         Int           @default(1)
  children       Int           @default(0)
  idProofType    IdProofType?  @map("id_proof_type")
  idProofNumber  String?       @map("id_proof_number")
  idProofLabel   String?       @map("id_proof_label")
  subtotal       Decimal       @db.Decimal(12, 2)
  gstAmount      Decimal       @map("gst_amount") @db.Decimal(12, 2)
  discountAmount Decimal       @default(0) @map("discount_amount") @db.Decimal(12, 2)
  totalAmount    Decimal       @map("total_amount") @db.Decimal(12, 2)
  status         BookingStatus @default(PENDING)
  checkedInAt    DateTime?     @map("checked_in_at")
  qrCode         String        @unique @default(cuid()) @map("qr_code") // scanned at gate; different from bookingNumber
  couponId       String?       @map("coupon_id")
  notes          String?       @db.Text
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  user              User?                @relation(fields: [userId], references: [id])
  coupon            Coupon?              @relation(fields: [couponId], references: [id])
  bookingTickets    BookingTicket[]
  participants      BookingParticipant[]
  transactions      Transaction[]
  couponRedemptions CouponRedemption[]
  rideAccessLogs    RideAccessLog[]
  foodOrders        FoodOrder[]
  lockerAssignments LockerAssignment[]
  costumeRentals    CostumeRental[]

  @@index([userId])
  @@index([guestMobile])
  @@index([guestMobile, createdAt]) // guest booking history lookup sorted by latest
  @@index([visitDate])
  @@index([status])
  @@index([visitDate, status]) // daily capacity check + ops dashboard
  @@index([couponId])
  @@map("booking")
}

/// Line items within a booking — one row per ticket type selected.
/// unitPrice and gstRate are locked at booking creation (price snapshot).
/// totalPrice = quantity × unitPrice (pre-GST subtotal for this line).
/// Hard delete: cascades if parent booking is hard-deleted (app prevents this).
model BookingTicket {
  id           String   @id @default(cuid())
  bookingId    String   @map("booking_id")
  ticketTypeId String   @map("ticket_type_id")
  quantity     Int
  unitPrice    Decimal  @map("unit_price") @db.Decimal(12, 2) // price at time of booking
  gstRate      Decimal  @map("gst_rate") @db.Decimal(5, 2) // GST rate at time of booking
  totalPrice   Decimal  @map("total_price") @db.Decimal(12, 2) // quantity × unitPrice (pre-GST)
  createdAt    DateTime @default(now()) @map("created_at")

  booking    Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])

  @@index([bookingId])
  @@index([ticketTypeId])
  @@map("booking_ticket")
}

model BookingParticipant {
  id           String   @id @default(cuid())
  bookingId    String   @map("booking_id")
  name         String   @default("")
  gender       Gender?
  age          Int?
  ticketTypeId String   @map("ticket_type_id")
  isLeadGuest  Boolean  @default(false) @map("is_lead_guest")
  createdAt    DateTime @default(now()) @map("created_at")

  booking    Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id])

  @@index([bookingId])
  @@index([ticketTypeId])
  @@map("booking_participant")
}

// =============================================================================
// PAYMENTS
// =============================================================================

/// Financial transaction record. A booking may have multiple transactions
/// (failed attempt + retry, or partial payments in Phase 2).
/// paymentId is unique per Razorpay payment_id for webhook dedup.
/// No soft delete — regulatory and financial audit requirement.
model Transaction {
  id            String            @id @default(cuid())
  bookingId     String            @map("booking_id")
  posSessionId  String?           @map("pos_session_id") // null for online payments
  amount        Decimal           @db.Decimal(12, 2)
  method        TransactionMethod
  status        TransactionStatus @default(PENDING)
  gatewayRef    String?           @map("gateway_ref") // Razorpay order_id
  paymentId     String?           @unique @map("payment_id") // Razorpay payment_id; unique for webhook dedup
  upiRef        String?           @map("upi_ref") // UTR / UPI transaction reference from guest
  upiScreenshot String?           @map("upi_screenshot") // relative path: upi-screenshots/YYYY/MM/{uuid}.jpg
  verifiedById  String?           @map("verified_by_id")
  verifiedAt    DateTime?         @map("verified_at")
  notes         String?           @db.Text
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  booking    Booking     @relation(fields: [bookingId], references: [id])
  posSession PosSession? @relation(fields: [posSessionId], references: [id])
  verifiedBy User?       @relation("TransactionVerifier", fields: [verifiedById], references: [id])

  @@index([bookingId])
  @@index([posSessionId])
  @@index([bookingId, status])
  @@index([status])
  @@index([method, status])
  @@index([method, status, createdAt])
  @@index([gatewayRef])
  @@index([verifiedById])
  @@map("transaction")
}

/// POS cash drawer session — one per terminal per shift.
/// Tracks opening float, all cash collected, and closing count for reconciliation.
model PosSession {
  id           String           @id @default(cuid())
  terminalId   String           @map("terminal_id") // e.g. "GATE_1", "FB_1", "LOCKER_1"
  staffId      String           @map("staff_id")
  openedAt     DateTime         @default(now()) @map("opened_at")
  closedAt     DateTime?        @map("closed_at")
  openingCash  Decimal          @map("opening_cash") @db.Decimal(12, 2)
  closingCash  Decimal?         @map("closing_cash") @db.Decimal(12, 2)
  expectedCash Decimal?         @map("expected_cash") @db.Decimal(12, 2) // computed: openingCash + all CASH transactions
  variance     Decimal?         @db.Decimal(12, 2) // closingCash - expectedCash
  status       PosSessionStatus @default(OPEN)
  notes        String?          @db.Text
  createdAt    DateTime         @default(now()) @map("created_at")

  staff          User            @relation("PosSessionStaff", fields: [staffId], references: [id])
  transactions   Transaction[]
  costumeRentals CostumeRental[]

  @@index([staffId])
  @@index([terminalId, status])
  @@index([openedAt])
  @@map("pos_session")
}

// =============================================================================
// GUEST CRM
// =============================================================================

/// Persistent guest record, keyed by mobile number.
/// Created or updated on every booking — works for guests with or without accounts.
/// Denormalized counters (totalVisits, totalSpend, loyaltyPoints) updated atomically
/// by application after each confirmed visit.
/// No soft delete — lifetime guest history must be preserved.
model GuestProfile {
  id              String    @id @default(cuid())
  mobile          String    @unique
  name            String
  email           String?
  dob             DateTime? @db.Date // DATE only; used for birthday campaigns
  anniversaryDate DateTime? @map("anniversary_date") @db.Date // DATE only; used for anniversary campaigns
  totalVisits     Int       @default(0) @map("total_visits")
  totalSpend      Decimal   @default(0) @map("total_spend") @db.Decimal(12, 2)
  loyaltyPoints   Int       @default(0) @map("loyalty_points")
  tier            GuestTier @default(BRONZE)
  lastVisitDate   DateTime? @map("last_visit_date") @db.Date
  tags            String[]  @default([]) // free-form labels: ["vip","school-group","corporate"]
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  loyaltyTransactions LoyaltyTransaction[]

  @@index([mobile])
  @@index([tier])
  @@index([lastVisitDate])
  @@map("guest_profile")
}

/// Append-only points ledger for each guest.
/// points: positive = EARN/ADJUST-up; negative = REDEEM/EXPIRE/ADJUST-down.
/// referenceId links to the bookingId or admin action that caused the change.
/// Hard delete: never — financial / loyalty audit trail.
model LoyaltyTransaction {
  id             String      @id @default(cuid())
  guestProfileId String      @map("guest_profile_id")
  points         Int // signed integer
  type           LoyaltyType
  description    String?     @db.Text
  referenceId    String?     @map("reference_id") // bookingId, "expiry-run-YYYY-MM", etc.
  referenceType  String?     @map("reference_type") // "booking" | "manual" | "expiry"
  createdAt      DateTime    @default(now()) @map("created_at")

  guestProfile GuestProfile @relation(fields: [guestProfileId], references: [id], onDelete: Cascade)

  @@index([guestProfileId])
  @@index([guestProfileId, type]) // filter ledger by transaction type
  @@index([createdAt])
  @@map("loyalty_transaction")
}

// =============================================================================
// RIDES
// =============================================================================

/// Individual ride or attraction within a zone.
/// status is the operational control flag; isDeleted removes from system entirely.
/// operatorId: currently assigned RIDE_OPERATOR (nullable = unassigned).
/// Soft delete: isDeleted — RideAccessLog references must remain resolvable.
model Ride {
  id          String     @id @default(cuid())
  name        String
  description String?    @db.Text
  zoneId      String     @map("zone_id")
  entryFee    Decimal    @default(0) @map("entry_fee") @db.Decimal(12, 2)
  gstRate     Decimal    @default(18) @map("gst_rate") @db.Decimal(5, 2)
  minHeight   Int?       @map("min_height") // cm; null = no restriction
  maxWeight   Int?       @map("max_weight") // kg; null = no restriction
  durationMin Int        @default(5) @map("duration_min")
  capacity    Int        @default(20) // riders per session
  status      RideStatus @default(ACTIVE)
  imageUrl    String?    @map("image_url")
  operatorId  String?    @map("operator_id") // currently assigned staff user
  sortOrder   Int        @default(0) @map("sort_order")
  isDeleted   Boolean    @default(false) @map("is_deleted")
  deletedAt   DateTime?  @map("deleted_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  zone           Zone            @relation(fields: [zoneId], references: [id])
  operator       User?           @relation("RideOperator", fields: [operatorId], references: [id])
  rideAccessLogs RideAccessLog[]
  workOrders     WorkOrder[]
  ticketTypes    TicketType[]
  packageItems   SalesPackageItem[] @relation("PackageRide")

  @@index([zoneId])
  @@index([status])
  @@index([operatorId])
  @@index([isDeleted])
  @@map("ride")
}

/// Scan log when a guest uses their booking QR to board a ride.
/// Append-only. scannedBy = userId of operator who processed the scan (null for kiosk).
/// Hard delete: never — utilisation and safety audit trail.
model RideAccessLog {
  id        String   @id @default(cuid())
  rideId    String   @map("ride_id")
  bookingId String   @map("booking_id")
  scannedAt DateTime @default(now()) @map("scanned_at")
  scannedBy String?  @map("scanned_by") // userId of operator; null = self-service kiosk

  ride    Ride    @relation(fields: [rideId], references: [id])
  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([rideId])
  @@index([bookingId])
  @@index([scannedAt])
  @@index([rideId, scannedAt]) // ride utilisation report by time window
  @@map("ride_access_log")
}

// =============================================================================
// STAFF
// =============================================================================

/// Master list of departments used across staff management LOVs.
/// Soft delete via isDeleted so historical staff rows remain readable.
model DepartmentMaster {
  id        String    @id @default(cuid())
  name      String    @unique
  code      String?   @unique
  isActive  Boolean   @default(true) @map("is_active")
  isDeleted Boolean   @default(false) @map("is_deleted")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([isActive, isDeleted])
  @@map("department_master")
}

/// Extended HR profile for EMPLOYEE-role users. One-to-one with User.
/// isActive here mirrors User.isActive but allows independent HR deactivation
/// without blocking the User's authentication record.
/// No separate soft delete — deactivation via isActive.
model StaffProfile {
  id           String   @id @default(cuid())
  userId       String   @unique @map("user_id")
  employeeCode String   @unique @map("employee_code") // e.g. WP-EMP-0042
  department   String?
  joiningDate  DateTime @map("joining_date") @db.Date
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  shifts Shift[]

  @@index([userId])
  @@index([employeeCode])
  @@index([isActive])
  @@map("staff_profile")
}

/// Daily shift and clock-in/out record per staff member.
/// startTime / endTime: full DateTime (UTC) for actual clock-in and clock-out.
/// endTime null = shift ongoing or not yet clocked out.
/// No soft delete — payroll and compliance audit trail.
model Shift {
  id        String    @id @default(cuid())
  staffId   String    @map("staff_id")
  shiftDate DateTime  @map("shift_date") @db.Date // DATE only — the calendar day of the shift
  shiftType ShiftType @map("shift_type")
  startTime DateTime  @map("start_time") // full DateTime UTC — actual clock-in
  endTime   DateTime? @map("end_time") // null if shift is ongoing
  isPresent Boolean   @default(false) @map("is_present")
  notes     String?   @db.Text
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  staff StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([staffId])
  @@index([shiftDate])
  @@index([staffId, shiftDate]) // daily attendance lookup per staff
  @@map("shift")
}

// =============================================================================
// SALES CRM — LEADS
// =============================================================================

/// Prospective group / corporate booking leads tracked through pipeline stages.
/// assignedTo: userId of SALES_EXECUTIVE or ADMIN managing the lead.
/// followUpAt: full DateTime (UTC) for scheduled follow-up call time.
/// Soft delete: isDeleted — preserve sales history even for dead leads.
model Lead {
  id                String     @id @default(cuid())
  name              String
  mobile            String
  email             String?
  source            LeadSource @default(WEBSITE)
  stage             LeadStage  @default(NEW)
  groupSize         Int?       @map("group_size")
  visitDateExpected DateTime?  @map("visit_date_expected") @db.Date // DATE only
  budgetEstimate    Decimal?   @map("budget_estimate") @db.Decimal(12, 2)
  notes             String?    @db.Text
  assignedTo        String?    @map("assigned_to")
  followUpAt        DateTime?  @map("follow_up_at") // full DateTime for scheduled call
  lostReason        String?    @map("lost_reason") @db.Text
  isDeleted         Boolean    @default(false) @map("is_deleted")
  deletedAt         DateTime?  @map("deleted_at")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  assignee   User?          @relation("LeadAssignee", fields: [assignedTo], references: [id])
  activities LeadActivity[]

  @@index([mobile])
  @@index([stage])
  @@index([assignedTo])
  @@index([followUpAt])
  @@index([followUpAt, stage]) // due follow-ups filtered by active stage
  @@index([stage, followUpAt]) // follow-up dashboard: active stages with due reminders
  @@index([isDeleted])
  @@map("lead")
}

/// Append-only activity log per lead (calls, emails, notes, stage changes).
/// activityType: open String — "CALL" | "EMAIL" | "WHATSAPP" | "MEETING" | "NOTE" | "STAGE_CHANGE"
/// Not an enum to allow future types without schema migrations.
/// Hard delete: never — CRM audit trail.
model LeadActivity {
  id           String   @id @default(cuid())
  leadId       String   @map("lead_id")
  activityType String   @map("activity_type")
  notes        String?  @db.Text
  performedBy  String   @map("performed_by") // userId
  createdAt    DateTime @default(now()) @map("created_at")

  lead      Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  performer User @relation(fields: [performedBy], references: [id])

  @@index([leadId])
  @@index([performedBy])
  @@index([leadId, createdAt]) // activity feed in chronological order
  @@map("lead_activity")
}

// =============================================================================
// COUPONS
// =============================================================================

/// Discount coupon configuration.
/// usedCount incremented atomically by application on each redemption.
/// maxDiscountCap applies only to PERCENTAGE type (caps the rupee discount).
/// applicableFor: coarse category guard — "ALL" | "ADULT" | "CHILD" | "GROUP".
/// For ticket-type-level granularity, populate CouponTicketType junction.
/// Soft delete: isDeleted — preserve redemption references on linked Bookings.
model Coupon {
  id                    String             @id @default(cuid())
  code                  String             @unique
  title                 String?
  description           String?            @db.Text
  discountType          CouponDiscountType @map("discount_type")
  discountValue         Decimal            @map("discount_value") @db.Decimal(12, 2) // % value or ₹ flat amount
  minOrderAmount        Decimal?           @map("min_order_amount") @db.Decimal(12, 2) // booking must be ≥ this amount
  minBookingAmount      Decimal?           @map("min_booking_amount") @db.Decimal(12, 2)
  minGuests             Int?               @map("min_guests")
  maxDiscountCap        Decimal?           @map("max_discount_cap") @db.Decimal(12, 2) // max ₹ discount for PERCENTAGE type
  maxUses               Int?               @map("max_uses") // null = unlimited
  maxUsesPerUser        Int?               @default(1) @map("max_uses_per_user")
  currentUses           Int                @default(0) @map("current_uses")
  usedCount             Int                @default(0) @map("used_count")
  validFrom             DateTime           @map("valid_from") // full DateTime — precise activation time
  validUntil            DateTime?          @map("valid_until")
  validTo               DateTime           @map("valid_to") // full DateTime — precise expiry time
  validDays             WeekDay[]          @default([]) @map("valid_days")
  validForDates         DateTime[]         @default([]) @map("valid_for_dates")
  target                CouponTarget       @default(ALL)
  allowedTiers          GuestTier[]        @default([]) @map("allowed_tiers")
  appliesTo             CouponAppliesTo    @default(ALL_TICKETS) @map("applies_to")
  buyXQty               Int?               @map("buy_x_qty")
  buyYQty               Int?               @map("buy_y_qty")
  freeTicketTypeId      String?            @map("free_ticket_type_id")
  flatPerTicketAmount   Decimal?           @map("flat_per_ticket_amount") @db.Decimal(12, 2)
  foodDiscountValue     Decimal?           @map("food_discount_value") @db.Decimal(12, 2)
  foodDiscountIsPercent Boolean            @default(true) @map("food_discount_is_percent")
  corporateCode         String?            @map("corporate_code")
  isPublicOffer         Boolean            @default(true) @map("is_public_offer")
  isActive              Boolean            @default(true) @map("is_active")
  applicableFor         String             @default("ALL") @map("applicable_for") // coarse guard
  isDeleted             Boolean            @default(false) @map("is_deleted")
  deletedAt             DateTime?          @map("deleted_at")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")

  bookings          Booking[]
  couponTicketTypes CouponTicketType[]
  freeTicketType    TicketType?        @relation("CouponFreeTicketType", fields: [freeTicketTypeId], references: [id])
  redemptions       CouponRedemption[]

  @@index([code])
  @@index([isActive, isDeleted])
  @@index([validFrom, validTo]) // validity window filter during checkout
  @@index([currentUses])
  @@index([target, isActive])
  @@index([isPublicOffer, isActive])
  @@map("coupon")
}

/// Junction table for granular coupon → ticket type restriction.
/// If NO rows exist for a coupon → applicableFor string governs.
/// If rows exist → coupon applies ONLY to the listed ticket types.
model CouponTicketType {
  id           String @id @default(cuid())
  couponId     String @map("coupon_id")
  ticketTypeId String @map("ticket_type_id")

  coupon     Coupon     @relation(fields: [couponId], references: [id], onDelete: Cascade)
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)

  @@unique([couponId, ticketTypeId])
  @@index([couponId])
  @@index([ticketTypeId])
  @@map("coupon_ticket_type")
}

model CouponRedemption {
  id             String   @id @default(cuid())
  couponId       String   @map("coupon_id")
  bookingId      String?  @map("booking_id")
  userId         String?  @map("user_id")
  mobile         String   @map("mobile")
  discountAmount Decimal  @map("discount_amount") @db.Decimal(12, 2)
  createdAt      DateTime @default(now()) @map("created_at")

  coupon  Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([couponId])
  @@index([bookingId])
  @@index([mobile, couponId])
  @@index([couponId, createdAt])
  @@map("coupon_redemption")
}

// =============================================================================
// MAINTENANCE
// =============================================================================

/// Physical asset tracked for service scheduling and work orders
/// (rides, pumps, generators, HVAC, electrical panels, etc.).
/// Ride model has its own record; link via WorkOrder.rideId — no direct FK
/// to avoid circular dependency.
/// Soft delete: isDeleted — work order history must remain resolvable.
model MaintenanceAsset {
  id              String    @id @default(cuid())
  name            String
  assetType       String    @map("asset_type") // "RIDE" | "PUMP" | "ELECTRICAL" | "HVAC" | "GENERATOR" | "OTHER"
  location        String?
  serialNumber    String?   @unique @map("serial_number")
  purchaseDate    DateTime? @map("purchase_date") @db.Date
  warrantyExpiry  DateTime? @map("warranty_expiry") @db.Date
  lastServiceDate DateTime? @map("last_service_date") @db.Date
  nextServiceDate DateTime? @map("next_service_date") @db.Date
  isActive        Boolean   @default(true) @map("is_active")
  isDeleted       Boolean   @default(false) @map("is_deleted")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  workOrders WorkOrder[]

  @@index([assetType])
  @@index([isActive])
  @@index([nextServiceDate]) // service-due alert query
  @@map("maintenance_asset")
}

/// Work order for corrective or preventive maintenance.
/// rideId optionally links to the affected ride so operators see the work order.
/// assignedTo: MAINTENANCE_TECH userId.
/// createdBy: ADMIN or MAINTENANCE_TECH userId.
/// Soft delete: isDeleted — safety and compliance audit trail.
model WorkOrder {
  id              String            @id @default(cuid())
  assetId         String            @map("asset_id")
  rideId          String?           @map("ride_id") // optional — links work order to a ride
  title           String
  description     String?           @db.Text
  priority        WorkOrderPriority @default(MEDIUM)
  status          WorkOrderStatus   @default(OPEN)
  assignedTo      String?           @map("assigned_to")
  dueDate         DateTime?         @map("due_date") @db.Date
  completedAt     DateTime?         @map("completed_at")
  resolutionNotes String?           @map("resolution_notes") @db.Text
  createdBy       String            @map("created_by")
  isDeleted       Boolean           @default(false) @map("is_deleted")
  deletedAt       DateTime?         @map("deleted_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  asset    MaintenanceAsset @relation(fields: [assetId], references: [id])
  ride     Ride?            @relation(fields: [rideId], references: [id])
  assignee User?            @relation("WorkOrderAssignee", fields: [assignedTo], references: [id])
  creator  User             @relation("WorkOrderCreator", fields: [createdBy], references: [id])

  @@index([assetId])
  @@index([rideId])
  @@index([status])
  @@index([priority])
  @@index([assignedTo])
  @@index([dueDate])
  @@index([status, priority]) // maintenance dashboard: open CRITICAL first
  @@index([isDeleted])
  @@map("work_order")
}

// =============================================================================
// COMMUNICATION
// =============================================================================

/// Reusable message templates for all outbound channels.
/// variables: declared placeholder names for validation e.g. ["guestName","bookingNumber","visitDate"].
/// body uses {{variableName}} syntax (resolved in application before sending).
/// No soft delete — isActive flag controls availability.
model MessageTemplate {
  id        String               @id @default(cuid())
  name      String               @unique
  channel   CommunicationChannel
  subject   String? // Email subject line; null for SMS / WhatsApp / Push
  body      String               @db.Text // Template with {{variable}} placeholders
  variables String[]             @default([])
  isActive  Boolean              @default(true) @map("is_active")
  createdAt DateTime             @default(now()) @map("created_at")
  updatedAt DateTime             @updatedAt @map("updated_at")

  communicationLogs CommunicationLog[]

  @@index([channel])
  @@index([isActive])
  @@map("message_template")
}

/// Append-only outbound message log for deliverability and compliance audit.
/// payload: the fully rendered message (JSON) stored for debugging failed messages.
/// referenceId + referenceType: polymorphic link to the triggering entity
/// (booking, lead, guest) without a hard FK.
/// Hard delete: never.
model CommunicationLog {
  id              String               @id @default(cuid())
  recipientMobile String?              @map("recipient_mobile")
  recipientEmail  String?              @map("recipient_email")
  channel         CommunicationChannel
  templateId      String?              @map("template_id")
  status          MessageStatus        @default(QUEUED)
  payload         Json? // rendered message body for audit
  sentAt          DateTime?            @map("sent_at")
  errorMessage    String?              @map("error_message") @db.Text
  referenceId     String?              @map("reference_id") // bookingId | leadId | guestProfileId
  referenceType   String?              @map("reference_type") // "booking" | "lead" | "guest"
  createdAt       DateTime             @default(now()) @map("created_at")

  template MessageTemplate? @relation(fields: [templateId], references: [id])

  @@index([recipientMobile])
  @@index([recipientMobile, createdAt]) // recipient delivery timeline lookups
  @@index([channel, status])
  @@index([templateId])
  @@index([referenceId, referenceType]) // "all messages for booking X"
  @@index([sentAt])
  @@index([status])
  @@map("communication_log")
}

// =============================================================================
// FOOD & BEVERAGE
// =============================================================================

/// Physical food outlet / stall within the park (e.g. "Wave Pool Café", "Main Food Court").
/// isOpen: operator can toggle during the day without deactivating the outlet.
model FoodOutlet {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  location    String?
  isOpen      Boolean  @default(true) @map("is_open")
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  categories FoodCategory[]
  orders     FoodOrder[]

  @@index([isActive])
  @@map("food_outlet")
}

/// Menu category within an outlet (e.g. "Starters", "Beverages", "Combos").
model FoodCategory {
  id        String   @id @default(cuid())
  outletId  String   @map("outlet_id")
  name      String
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  outlet FoodOutlet @relation(fields: [outletId], references: [id], onDelete: Cascade)
  items  FoodItem[]

  @@index([outletId])
  @@map("food_category")
}

/// Menu item. preBookPrice is the discounted price shown during the booking flow.
/// Prices are snapshotted on FoodOrderItem at order time.
model FoodItem {
  id           String    @id @default(cuid())
  categoryId   String    @map("category_id")
  name         String
  description  String?   @db.Text
  sku          String?   @map("sku")
  price        Decimal   @db.Decimal(12, 2)
  preBookPrice Decimal?  @map("pre_book_price") @db.Decimal(12, 2) // null = no pre-book discount
  gstRate      Decimal   @default(5) @map("gst_rate") @db.Decimal(5, 2)
  prepTimeMin  Int?      @map("prep_time_min")
  allergens    String[]  @default([])
  isVeg        Boolean   @default(true) @map("is_veg")
  isFeatured   Boolean   @default(false) @map("is_featured")
  isAvailable  Boolean   @default(true) @map("is_available")
  imageUrl     String?   @map("image_url")
  sortOrder    Int       @default(0) @map("sort_order")
  isDeleted    Boolean   @default(false) @map("is_deleted")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  category   FoodCategory      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems FoodOrderItem[]
  variants   FoodItemVariant[]
  modifierGroups FoodModifierGroup[]
  packageItems SalesPackageItem[] @relation("PackageFoodItem")

  @@index([categoryId])
  @@index([isAvailable, isDeleted])
  @@map("food_item")
}

/// Modifier group for a food item (e.g. Spice Level, Add-ons, Extras).
model FoodModifierGroup {
  id          String   @id @default(cuid())
  foodItemId  String   @map("food_item_id")
  name        String
  minSelect   Int      @default(0) @map("min_select")
  maxSelect   Int      @default(1) @map("max_select")
  isRequired  Boolean  @default(false) @map("is_required")
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  foodItem FoodItem @relation(fields: [foodItemId], references: [id], onDelete: Cascade)
  options  FoodModifierOption[]

  @@index([foodItemId])
  @@index([isActive])
  @@map("food_modifier_group")
}

/// Option inside a modifier group (e.g. Extra Cheese +₹30, No Onion +₹0).
model FoodModifierOption {
  id        String   @id @default(cuid())
  groupId   String   @map("group_id")
  name      String
  price     Decimal  @db.Decimal(12, 2)
  sortOrder Int      @default(0) @map("sort_order")
  isDefault Boolean  @default(false) @map("is_default")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  group FoodModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  orderItemModifiers FoodOrderItemModifier[]

  @@index([groupId])
  @@index([isActive])
  @@map("food_modifier_option")
}

/// Variant under a food item (e.g. Small/Medium/Large, Half/Full).
model FoodItemVariant {
  id           String   @id @default(cuid())
  foodItemId   String   @map("food_item_id")
  name         String
  sku          String?  @map("sku")
  price        Decimal  @db.Decimal(12, 2)
  preBookPrice Decimal? @map("pre_book_price") @db.Decimal(12, 2)
  sortOrder    Int      @default(0) @map("sort_order")
  isDefault    Boolean  @default(false) @map("is_default")
  isAvailable  Boolean  @default(true) @map("is_available")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  foodItem   FoodItem        @relation(fields: [foodItemId], references: [id], onDelete: Cascade)
  orderItems FoodOrderItem[]
  packageItems SalesPackageItem[] @relation("PackageFoodVariant")

  @@index([foodItemId])
  @@index([isAvailable])
  @@map("food_item_variant")
}

/// A single order transaction at an outlet.
/// token: 3-digit zero-padded number per outlet per day (from Redis INCR).
///        null for pre-booked orders until staff activates them at the counter.
/// bookingId: non-null only for pre-booked orders linked to a booking.
model FoodOrder {
  id            String           @id @default(cuid())
  outletId      String           @map("outlet_id")
  bookingId     String?          @map("booking_id")
  token         String?          @map("token") // "042" — assigned at order creation for walk-in, at activation for pre-booked
  guestName     String           @map("guest_name")
  guestMobile   String?          @map("guest_mobile")
  subtotal      Decimal          @db.Decimal(12, 2)
  gstAmount     Decimal          @map("gst_amount") @db.Decimal(12, 2)
  totalAmount   Decimal          @map("total_amount") @db.Decimal(12, 2)
  paymentMethod FnbPaymentMethod @map("payment_method")
  status        FoodOrderStatus  @default(PENDING)
  notes         String?          @db.Text
  staffId       String?          @map("staff_id")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  outlet     FoodOutlet      @relation(fields: [outletId], references: [id])
  booking    Booking?        @relation(fields: [bookingId], references: [id])
  staff      User?           @relation("FoodOrderStaff", fields: [staffId], references: [id])
  orderItems FoodOrderItem[]

  @@index([outletId])
  @@index([bookingId])
  @@index([outletId, createdAt]) // daily orders per outlet
  @@index([status])
  @@index([token])
  @@map("food_order")
}

/// Line items within a food order. Prices snapshotted at order time.
model FoodOrderItem {
  id            String  @id @default(cuid())
  orderId       String  @map("order_id")
  foodItemId    String  @map("food_item_id")
  foodVariantId String? @map("food_variant_id")
  name          String // snapshot — item name at time of order
  variantName   String? @map("variant_name") // snapshot — variant label at time of order
  quantity      Int
  unitPrice     Decimal @map("unit_price") @db.Decimal(12, 2)
  gstRate       Decimal @map("gst_rate") @db.Decimal(5, 2)
  totalPrice    Decimal @map("total_price") @db.Decimal(12, 2) // quantity × unitPrice (pre-GST)

  order       FoodOrder        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  foodItem    FoodItem         @relation(fields: [foodItemId], references: [id])
  foodVariant FoodItemVariant? @relation(fields: [foodVariantId], references: [id])
  modifiers   FoodOrderItemModifier[]

  @@index([orderId])
  @@index([foodItemId])
  @@index([foodVariantId])
  @@map("food_order_item")
}

/// Snapshotted modifiers selected for a food order line item.
model FoodOrderItemModifier {
  id          String  @id @default(cuid())
  orderItemId String  @map("order_item_id")
  groupId     String? @map("group_id")
  optionId    String? @map("option_id")
  groupName   String  @map("group_name")
  optionName  String  @map("option_name")
  quantity    Int     @default(1)
  unitPrice   Decimal @map("unit_price") @db.Decimal(12, 2)
  totalPrice  Decimal @map("total_price") @db.Decimal(12, 2)

  orderItem FoodOrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  option    FoodModifierOption? @relation(fields: [optionId], references: [id], onDelete: SetNull)

  @@index([orderItemId])
  @@index([optionId])
  @@map("food_order_item_modifier")
}

// =============================================================================
// LOCKER MANAGEMENT
// =============================================================================

/// Physical zone where lockers are installed (e.g. "Wave Pool Area", "Main Entrance").
model LockerZone {
  id       String  @id @default(cuid())
  name     String
  location String?
  isActive Boolean @default(true) @map("is_active")

  lockers Locker[]

  @@index([isActive])
  @@map("locker_zone")
}

/// Individual locker unit. Identified by a human-readable number (e.g. "A-042").
model Locker {
  id       String       @id @default(cuid())
  zoneId   String       @map("zone_id")
  number   String       @unique
  size     LockerSize   @default(MEDIUM)
  rate     Decimal      @default(299) @map("rate") @db.Decimal(12, 2)
  gstRate  Decimal      @default(18) @map("gst_rate") @db.Decimal(5, 2)
  status   LockerStatus @default(AVAILABLE)
  isActive Boolean      @default(true) @map("is_active")

  zone        LockerZone         @relation(fields: [zoneId], references: [id])
  assignments LockerAssignment[]
  packageItems SalesPackageItem[] @relation("PackageLocker")

  @@index([zoneId])
  @@index([status])
  @@index([zoneId, status])
  @@map("locker")
}

/// A single locker rental assignment.
/// dueAt computed from assignedAt + duration (hourly or full-day).
/// returnedAt null = locker still in use.
/// No soft delete — financial and audit record.
model LockerAssignment {
  id            String             @id @default(cuid())
  lockerId      String             @map("locker_id")
  bookingId     String?            @map("booking_id")
  guestName     String             @map("guest_name")
  guestMobile   String             @map("guest_mobile")
  assignedById  String             @map("assigned_by_id")
  durationType  LockerDurationType @map("duration_type")
  assignedAt    DateTime           @default(now()) @map("assigned_at")
  dueAt         DateTime           @map("due_at")
  returnedAt    DateTime?          @map("returned_at")
  returnedById  String?            @map("returned_by_id")
  amount        Decimal            @db.Decimal(12, 2)
  paymentMethod String             @default("CASH") @map("payment_method")
  notes         String?            @db.Text
  createdAt     DateTime           @default(now()) @map("created_at")

  locker     Locker   @relation(fields: [lockerId], references: [id])
  assignedBy User     @relation("LockerAssignedBy", fields: [assignedById], references: [id])
  returnedBy User?    @relation("LockerReturnedBy", fields: [returnedById], references: [id])
  booking    Booking? @relation(fields: [bookingId], references: [id])

  @@index([lockerId])
  @@index([assignedAt])
  @@index([guestMobile])
  @@index([bookingId])
  @@index([returnedAt]) // null = active assignments
  @@map("locker_assignment")
}

// =============================================================================
// COSTUME RENTAL MODELS
// =============================================================================

/// A costume category / type (e.g. "Mermaid", "Pirate", "Superhero").
model CostumeCategory {
  id          String  @id @default(cuid())
  name        String
  description String? @db.Text
  imageUrl    String? @map("image_url")
  isActive    Boolean @default(true) @map("is_active")
  sortOrder   Int     @default(0) @map("sort_order")

  items CostumeItem[]

  @@index([isActive])
  @@map("costume_category")
}

/// Individual costume unit (physical item with barcode/tag number).
model CostumeItem {
  id          String        @id @default(cuid())
  categoryId  String        @map("category_id")
  stockCode   String?       @map("stock_code")
  tagNumber   String        @unique @map("tag_number") // physical tag on the garment
  name        String // e.g. "Mermaid Dress - L"
  size        CostumeSize
  status      CostumeStatus @default(AVAILABLE)
  rentalRate  Decimal       @map("rental_rate") @db.Decimal(12, 2) // per session
  depositRate Decimal       @default(0) @map("deposit_rate") @db.Decimal(12, 2)
  gstRate     Decimal       @default(0) @map("gst_rate") @db.Decimal(5, 2)
  isActive    Boolean       @default(true) @map("is_active")
  notes       String?       @db.Text
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  category CostumeCategory @relation(fields: [categoryId], references: [id])
  rentals  CostumeRental[]
  packageItems SalesPackageItem[] @relation("PackageCostumeItem")

  @@index([categoryId])
  @@index([status])
  @@index([categoryId, status])
  @@index([stockCode])
  @@map("costume_item")
}

/// A single costume rental transaction.
/// depositPaid: cash held as security; refundedAt not null = deposit returned.
model CostumeRental {
  id                String    @id @default(cuid())
  costumeItemId     String    @map("costume_item_id")
  bookingId         String?   @map("booking_id")
  posSessionId      String?   @map("pos_session_id")
  guestName         String    @map("guest_name")
  guestMobile       String?   @map("guest_mobile")
  rentedById        String    @map("rented_by_id") // staff who issued
  returnedById      String?   @map("returned_by_id") // staff who accepted return
  rentedAt          DateTime  @default(now()) @map("rented_at")
  dueAt             DateTime  @map("due_at") // expected return time
  returnedAt        DateTime? @map("returned_at")
  rentalAmount      Decimal   @map("rental_amount") @db.Decimal(12, 2)
  depositAmount     Decimal   @default(0) @map("deposit_amount") @db.Decimal(12, 2)
  depositPaid       Boolean   @default(false) @map("deposit_paid")
  depositRefundedAt DateTime? @map("deposit_refunded_at")
  paymentMethod     String    @default("CASH") @map("payment_method")
  notes             String?   @db.Text
  condition         String?   @db.Text // condition note on return
  createdAt         DateTime  @default(now()) @map("created_at")

  costumeItem CostumeItem @relation(fields: [costumeItemId], references: [id])
  booking     Booking?    @relation(fields: [bookingId], references: [id])
  posSession  PosSession? @relation(fields: [posSessionId], references: [id])
  rentedBy    User        @relation("CostumeRentedBy", fields: [rentedById], references: [id])
  returnedBy  User?       @relation("CostumeReturnedBy", fields: [returnedById], references: [id])

  @@index([costumeItemId])
  @@index([bookingId])
  @@index([guestMobile])
  @@index([rentedAt])
  @@index([returnedAt])
  @@index([posSessionId])
  @@map("costume_rental")
}
